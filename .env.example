POSTGRES_DB="school_erp"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="123456789"
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/school_erp?schema=public"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/school_erp?schema=public"
# Local single-machine install:
# APP_URL="http://localhost:3000"
# LAN install by IP:
# APP_URL="http://192.168.1.50:3000"
# LAN install by hostname:
# APP_URL="http://school-server:3000"
# Optional HTTPS deployment:
# APP_URL="https://your-school-domain-or-hostname"
APP_URL="http://localhost:3000"
APP_PORT="3000"
APP_NAME="Vidyalaya"
SESSION_COOKIE_NAME="school_erp_session"
SESSION_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
DEFAULT_SCHOOL_NAME="Springfield Public School"
DEFAULT_ADMIN_EMAIL="admin@school.local"
DEFAULT_ADMIN_PASSWORD="123456789"
BACKUP_DIR="./backups"
BACKUP_RETENTION_DAYS="14"
MIGRATE_ON_START="true"
SEED_ON_START="false"
PUBLIC_BASE_URL=""
CF_TUNNEL_HOSTNAME=""
CF_TUNNEL_ENABLED="false"
NODE_ENV="production"
