generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum RoleCode {
  SUPER_ADMIN
  ADMIN
  PRINCIPAL
  TEACHER
  ACCOUNTANT
  STUDENT
  PARENT
}

enum UserType {
  STAFF
  STUDENT
  PARENT
  SYSTEM
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
  HALF_DAY
}

enum FeeInvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum FeePaymentMode {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  CHEQUE
  OTHER
}

enum NoticeAudienceType {
  ALL
  ROLE
  STAFF
  STUDENTS
  PARENTS
  CLASS
  SECTION
}

enum DocumentOwnerType {
  SCHOOL
  STUDENT
  STAFF
  USER
}

model School {
  id             String          @id @default(cuid())
  name           String
  code           String          @unique
  slug           String          @unique
  phone          String?
  email          String?
  website        String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  postalCode     String?
  country        String          @default("India")
  timezone       String          @default("Asia/Kolkata")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  academicYears  AcademicYear[]
  users          User[]
  roles          Role[]
  permissions    Permission[]
  students       Student[]
  parents        Parent[]
  staffs         Staff[]
  classes        SchoolClass[]
  sections       Section[]
  subjects       Subject[]
  attendances    Attendance[]
  feeHeads       FeeHead[]
  feeStructures  FeeStructure[]
  feeInvoices    FeeInvoice[]
  feePayments    FeePayment[]
  exams          Exam[]
  notices        Notice[]
  documents      Document[]
  auditLogs      AuditLog[]
  settings       Setting[]
}

model AcademicYear {
  id          String       @id @default(cuid())
  schoolId    String
  name        String
  startDate   DateTime
  endDate     DateTime
  isCurrent   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students    Student[]
  staffs      Staff[]
  classes     SchoolClass[]
  sections    Section[]
  subjects    Subject[]
  exams       Exam[]
  attendances Attendance[]
  feeInvoices FeeInvoice[]

  @@unique([schoolId, name])
  @@index([schoolId, isCurrent])
}

model User {
  id            String        @id @default(cuid())
  schoolId      String
  fullName      String
  email         String        @unique
  passwordHash  String
  phone         String?
  userType      UserType      @default(STAFF)
  isActive      Boolean       @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  school        School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  roles         UserRole[]
  staffProfile  Staff?
  parentProfile Parent?
  documents     Document[]
  noticesCreated Notice[]
  auditLogs     AuditLog[]    @relation("AuditActor")

  @@index([schoolId, userType])
}

model Role {
  id          String           @id @default(cuid())
  schoolId    String
  code        RoleCode
  name        String
  description String?
  isSystem    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  school      School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  users       UserRole[]
  permissions RolePermission[]

  @@unique([schoolId, code])
}

model Permission {
  id          String           @id @default(cuid())
  schoolId    String
  code        String
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  school      School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  roles       RolePermission[]

  @@unique([schoolId, code])
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Parent {
  id             String            @id @default(cuid())
  schoolId       String
  userId         String?           @unique
  fatherName     String?
  motherName     String?
  guardianName   String
  relation       String
  phonePrimary   String
  phoneSecondary String?
  email          String?
  occupation     String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  postalCode     String?
  isArchived     Boolean           @default(false)
  archivedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  school         School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user           User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  students       StudentGuardian[]

  @@index([schoolId, phonePrimary])
  @@index([schoolId, isArchived])
}

model Student {
  id                String            @id @default(cuid())
  schoolId          String
  academicYearId    String
  admissionNumber   String
  rollNumber        String?
  firstName         String
  lastName          String?
  fullName          String
  gender            Gender?
  dateOfBirth       DateTime?
  admissionDate     DateTime
  status            String            @default("ACTIVE")
  classId           String?
  sectionId         String?
  bloodGroup        String?
  aadhaarNumber     String?
  religion          String?
  casteCategory     String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  postalCode        String?
  isArchived        Boolean           @default(false)
  archivedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear      AcademicYear      @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  class             SchoolClass?      @relation(fields: [classId], references: [id], onDelete: SetNull)
  section           Section?          @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  guardians         StudentGuardian[]
  attendances       Attendance[]
  feeInvoices       FeeInvoice[]
  examMarks         ExamMark[]
  examResults       ExamResult[]
  documents         Document[]

  @@unique([schoolId, admissionNumber])
  @@index([schoolId, academicYearId, classId, sectionId])
  @@index([schoolId, status, isArchived])
  @@index([schoolId, fullName])
}

model StudentGuardian {
  id         String   @id @default(cuid())
  studentId  String
  parentId   String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent     Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([studentId, parentId])
}

model Staff {
  id              String        @id @default(cuid())
  schoolId        String
  academicYearId  String
  userId          String?       @unique
  employeeCode    String
  fullName        String
  designation     String
  department      String?
  qualification   String?
  joiningDate     DateTime
  phone           String?
  email           String?
  gender          Gender?
  salaryAmount    Decimal?      @db.Decimal(12, 2)
  isTeachingStaff Boolean       @default(true)
  isArchived      Boolean       @default(false)
  archivedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  school          School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear    AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  classTeacherFor Section[]     @relation("ClassTeacher")
  documents       Document[]

  @@unique([schoolId, employeeCode])
  @@index([schoolId, academicYearId, designation])
  @@index([schoolId, isArchived, isTeachingStaff])
}

model SchoolClass {
  id             String          @id @default(cuid())
  schoolId       String
  academicYearId String
  name           String
  displayOrder   Int             @default(0)
  isArchived     Boolean         @default(false)
  archivedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  school         School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  sections       Section[]
  students       Student[]
  subjects       Subject[]
  feeStructures  FeeStructure[]
  exams          Exam[]
  notices        Notice[]

  @@unique([schoolId, academicYearId, name])
  @@index([schoolId, academicYearId, displayOrder, isArchived])
}

model Section {
  id               String          @id @default(cuid())
  schoolId         String
  academicYearId   String
  classId          String
  name             String
  classTeacherId   String?
  capacity         Int?
  isArchived       Boolean        @default(false)
  archivedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  school           School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear     AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  class            SchoolClass     @relation(fields: [classId], references: [id], onDelete: Cascade)
  classTeacher     Staff?          @relation("ClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)
  students         Student[]
  notices          Notice[]

  @@unique([schoolId, academicYearId, classId, name])
  @@index([schoolId, classId, isArchived])
}

model Subject {
  id             String         @id @default(cuid())
  schoolId       String
  academicYearId String
  classId        String?
  name           String
  code           String
  isArchived     Boolean        @default(false)
  archivedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  school         School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  class          SchoolClass?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  examSubjects   ExamSubject[]
  examMarks      ExamMark[]

  @@unique([schoolId, academicYearId, code])
  @@index([schoolId, academicYearId, classId, isArchived])
}

model Attendance {
  id             String           @id @default(cuid())
  schoolId       String
  academicYearId String
  studentId      String
  date           DateTime
  status         AttendanceStatus
  remarks        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  school         School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([schoolId, academicYearId, date])
  @@index([schoolId, academicYearId, studentId, date])
  @@index([schoolId, studentId, date])
}

model FeeHead {
  id          String             @id @default(cuid())
  schoolId    String
  name        String
  code        String
  description String?
  isOptional  Boolean            @default(false)
  isArchived  Boolean            @default(false)
  archivedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  school      School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  items       FeeStructureItem[]
  invoiceItems FeeInvoiceItem[]

  @@unique([schoolId, code])
  @@index([schoolId, isArchived])
}

model FeeStructure {
  id             String             @id @default(cuid())
  schoolId       String
  classId        String?
  name           String
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  isArchived     Boolean            @default(false)
  archivedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  school         School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class          SchoolClass?       @relation(fields: [classId], references: [id], onDelete: SetNull)
  items          FeeStructureItem[]

  @@index([schoolId, classId])
  @@index([schoolId, isArchived, effectiveFrom])
}

model FeeStructureItem {
  id             String        @id @default(cuid())
  feeStructureId String
  feeHeadId      String
  amount         Decimal       @db.Decimal(12, 2)
  createdAt      DateTime      @default(now())
  feeStructure   FeeStructure  @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  feeHead        FeeHead       @relation(fields: [feeHeadId], references: [id], onDelete: Restrict)

  @@unique([feeStructureId, feeHeadId])
}

model FeeInvoice {
  id             String           @id @default(cuid())
  schoolId       String
  academicYearId String
  studentId      String
  invoiceNumber  String
  dueDate        DateTime
  status         FeeInvoiceStatus @default(ISSUED)
  totalAmount    Decimal          @db.Decimal(12, 2)
  paidAmount     Decimal          @default(0) @db.Decimal(12, 2)
  discountAmount Decimal          @default(0) @db.Decimal(12, 2)
  fineAmount     Decimal          @default(0) @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  school         School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  items          FeeInvoiceItem[]
  payments       FeePayment[]

  @@unique([schoolId, invoiceNumber])
  @@index([schoolId, studentId, dueDate])
  @@index([schoolId, academicYearId, status, dueDate])
}

model FeePayment {
  id             String         @id @default(cuid())
  schoolId       String
  feeInvoiceId   String
  receiptNumber  String
  paymentDate    DateTime
  amount         Decimal        @db.Decimal(12, 2)
  paymentMode    FeePaymentMode
  referenceNo    String?
  remarks        String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  school         School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  feeInvoice     FeeInvoice     @relation(fields: [feeInvoiceId], references: [id], onDelete: Cascade)

  @@unique([schoolId, receiptNumber])
  @@index([schoolId, paymentDate])
  @@index([schoolId, feeInvoiceId, paymentDate])
}

model FeeInvoiceItem {
  id           String      @id @default(cuid())
  feeInvoiceId String
  feeHeadId    String
  label        String
  amount       Decimal     @db.Decimal(12, 2)
  createdAt    DateTime    @default(now())
  feeInvoice   FeeInvoice  @relation(fields: [feeInvoiceId], references: [id], onDelete: Cascade)
  feeHead      FeeHead     @relation(fields: [feeHeadId], references: [id], onDelete: Restrict)

  @@unique([feeInvoiceId, feeHeadId])
  @@index([feeInvoiceId])
}

model Exam {
  id             String        @id @default(cuid())
  schoolId       String
  academicYearId String
  classId        String?
  name           String
  examTerm       String?
  examType       String?
  startDate      DateTime
  endDate        DateTime
  isArchived     Boolean       @default(false)
  archivedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  class          SchoolClass?  @relation(fields: [classId], references: [id], onDelete: SetNull)
  examSubjects   ExamSubject[]
  examMarks      ExamMark[]
  results        ExamResult[]

  @@index([schoolId, academicYearId, startDate])
  @@index([schoolId, classId, startDate])
  @@index([schoolId, isArchived, startDate])
}

model ExamSubject {
  id          String    @id @default(cuid())
  examId      String
  subjectId   String
  maxMarks    Decimal   @db.Decimal(8, 2)
  passMarks   Decimal   @db.Decimal(8, 2)
  createdAt   DateTime  @default(now())
  exam        Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  examMarks   ExamMark[]

  @@unique([examId, subjectId])
}

model ExamMark {
  id            String    @id @default(cuid())
  examId        String
  examSubjectId String
  subjectId     String
  studentId     String
  marksObtained Decimal   @db.Decimal(8, 2)
  remarks       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  exam          Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  examSubject   ExamSubject @relation(fields: [examSubjectId], references: [id], onDelete: Cascade)
  subject       Subject   @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examSubjectId, studentId])
  @@index([examId, studentId])
}

model ExamResult {
  id               String   @id @default(cuid())
  examId           String
  studentId        String
  totalMarks       Decimal  @db.Decimal(10, 2)
  obtainedMarks    Decimal  @db.Decimal(10, 2)
  percentage       Decimal  @db.Decimal(6, 2)
  grade            String
  resultStatus     String
  teacherRemarks   String?
  principalRemarks String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  exam             Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@index([studentId, createdAt])
  @@index([examId, resultStatus])
}

model Notice {
  id             String             @id @default(cuid())
  schoolId       String
  title          String
  body           String
  audienceType   NoticeAudienceType @default(ALL)
  audienceLabel  String
  roleCode       String?
  classId        String?
  sectionId      String?
  noticeType     String             @default("NORMAL")
  isPublished    Boolean            @default(false)
  isArchived     Boolean            @default(false)
  archivedAt     DateTime?
  publishedAt    DateTime?
  expiresAt      DateTime?
  createdById    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  school         School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class          SchoolClass?       @relation(fields: [classId], references: [id], onDelete: SetNull)
  section        Section?           @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  createdBy      User?              @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([schoolId, publishedAt])
  @@index([schoolId, isPublished, noticeType])
  @@index([schoolId, classId, sectionId, isPublished])
  @@index([schoolId, isArchived, createdAt])
}

model Document {
  id              String             @id @default(cuid())
  schoolId        String
  ownerType       DocumentOwnerType
  studentId       String?
  staffId         String?
  userId          String?
  title           String
  fileName        String
  filePath        String
  mimeType        String?
  fileSizeBytes   Int?
  isArchived      Boolean            @default(false)
  archivedAt      DateTime?
  uploadedAt      DateTime           @default(now())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  school          School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student         Student?           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  staff           Staff?             @relation(fields: [staffId], references: [id], onDelete: Cascade)
  user            User?              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId, ownerType])
  @@index([schoolId, studentId])
  @@index([schoolId, staffId])
  @@index([schoolId, userId])
  @@index([schoolId, isArchived, uploadedAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  schoolId     String
  actorUserId  String?
  action       String
  entityType   String
  entityId     String?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  actor        User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([schoolId, createdAt])
  @@index([schoolId, action])
  @@index([schoolId, entityType, entityId, createdAt])
}

model Setting {
  id          String   @id @default(cuid())
  schoolId    String
  category    String
  key         String
  value       Json
  isSecret    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, category, key])
  @@index([schoolId, category])
}
