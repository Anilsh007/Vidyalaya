generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum RoleCode {
  SUPER_ADMIN
  ADMIN
  PRINCIPAL
  DIRECTOR
  HOD
  TEACHER
  EXAM_CONTROLLER
  ACCOUNTANT
  PROCUREMENT_MANAGER
  LIBRARIAN
  TRANSPORT_MANAGER
  HOSTEL_WARDEN
  FRONT_DESK
  HR
  NURSE
  SECURITY_GUARD
  MAINTENANCE_TECHNICIAN
  PEON
  STUDENT
  PARENT
}

enum UserType {
  STAFF
  STUDENT
  PARENT
  SYSTEM
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
  HALF_DAY
}

enum FeeInvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum FeePaymentMode {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  CHEQUE
  OTHER
}

enum LibraryIssueStatus {
  ISSUED
  RETURNED
  OVERDUE
  LOST
}

enum InventoryMovementType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  DAMAGED
  RETURNED
}

enum TransportAssignmentStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum HostelAllocationStatus {
  ACTIVE
  PAUSED
  VACATED
}

enum LeaveRequesterType {
  STUDENT
  STAFF
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollRunStatus {
  DRAFT
  FINALIZED
  PAID
  CANCELLED
}

enum PayrollSlipStatus {
  DRAFT
  APPROVED
  PAID
}

enum ExpenseVoucherStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}

enum NoticeAudienceType {
  ALL
  ROLE
  STAFF
  STUDENTS
  PARENTS
  CLASS
  SECTION
}

enum DocumentOwnerType {
  SCHOOL
  STUDENT
  STAFF
  USER
}

model School {
  id             String          @id @default(cuid())
  name           String
  code           String          @unique
  slug           String          @unique
  phone          String?
  email          String?
  website        String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  postalCode     String?
  country        String          @default("India")
  timezone       String          @default("Asia/Kolkata")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  academicYears  AcademicYear[]
  users          User[]
  roles          Role[]
  permissions    Permission[]
  students       Student[]
  parents        Parent[]
  staffs         Staff[]
  classes        SchoolClass[]
  sections       Section[]
  subjects       Subject[]
  attendances    Attendance[]
  feeHeads       FeeHead[]
  feeStructures  FeeStructure[]
  feeInvoices    FeeInvoice[]
  feePayments    FeePayment[]
  exams          Exam[]
  notices        Notice[]
  documents      Document[]
  libraryBooks   LibraryBook[]
  libraryIssues  LibraryIssue[]
  inventoryItems InventoryItem[]
  inventoryMovements InventoryMovement[]
  transportVehicles TransportVehicle[]
  transportRoutes TransportRoute[]
  transportStops TransportStop[]
  transportAssignments TransportAssignment[]
  hostels        Hostel[]
  hostelRooms    HostelRoom[]
  hostelAllocations HostelAllocation[]
  leaveRequests  LeaveRequest[]
  payrollRuns    PayrollRun[]
  payrollSlips   PayrollSlip[]
  expenseCategories ExpenseCategory[]
  expenseVouchers ExpenseVoucher[]
  auditLogs      AuditLog[]
  settings       Setting[]
}

model AcademicYear {
  id          String       @id @default(cuid())
  schoolId    String
  name        String
  startDate   DateTime
  endDate     DateTime
  isCurrent   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students    Student[]
  staffs      Staff[]
  classes     SchoolClass[]
  sections    Section[]
  subjects    Subject[]
  exams       Exam[]
  attendances Attendance[]
  feeInvoices FeeInvoice[]

  @@unique([schoolId, name])
  @@index([schoolId, isCurrent])
}

model User {
  id            String        @id @default(cuid())
  schoolId      String
  fullName      String
  email         String        @unique
  passwordHash  String
  phone         String?
  userType      UserType      @default(STAFF)
  isActive      Boolean       @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  school        School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  roles         UserRole[]
  staffProfile  Staff?
  studentProfile Student?
  parentProfile Parent?
  documents     Document[]
  noticesCreated Notice[]
  inventoryMovementsCreated InventoryMovement[] @relation("InventoryMovementCreatedBy")
  leaveRequestsReviewed LeaveRequest[] @relation("LeaveRequestReviewedBy")
  payrollRunsCreated PayrollRun[] @relation("PayrollRunCreatedBy")
  expenseVouchersApproved ExpenseVoucher[] @relation("ExpenseVoucherApprovedBy")
  auditLogs     AuditLog[]    @relation("AuditActor")

  @@index([schoolId, userType])
}

model Role {
  id          String           @id @default(cuid())
  schoolId    String
  code        RoleCode
  name        String
  description String?
  isSystem    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  school      School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  users       UserRole[]
  permissions RolePermission[]

  @@unique([schoolId, code])
}

model Permission {
  id          String           @id @default(cuid())
  schoolId    String
  code        String
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  school      School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  roles       RolePermission[]

  @@unique([schoolId, code])
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Parent {
  id             String            @id @default(cuid())
  schoolId       String
  userId         String?           @unique
  fatherName     String?
  motherName     String?
  guardianName   String
  relation       String
  phonePrimary   String
  phoneSecondary String?
  email          String?
  occupation     String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  postalCode     String?
  isArchived     Boolean           @default(false)
  archivedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  school         School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user           User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  students       StudentGuardian[]

  @@index([schoolId, phonePrimary])
  @@index([schoolId, isArchived])
}

model Student {
  id                String            @id @default(cuid())
  schoolId          String
  academicYearId    String
  userId            String?           @unique
  admissionNumber   String
  rollNumber        String?
  firstName         String
  lastName          String?
  fullName          String
  gender            Gender?
  dateOfBirth       DateTime?
  admissionDate     DateTime
  status            String            @default("ACTIVE")
  classId           String?
  sectionId         String?
  bloodGroup        String?
  aadhaarNumber     String?
  religion          String?
  casteCategory     String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  postalCode        String?
  isArchived        Boolean           @default(false)
  archivedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear      AcademicYear      @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  user              User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  class             SchoolClass?      @relation(fields: [classId], references: [id], onDelete: SetNull)
  section           Section?          @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  guardians         StudentGuardian[]
  attendances       Attendance[]
  feeInvoices       FeeInvoice[]
  examMarks         ExamMark[]
  examResults       ExamResult[]
  documents         Document[]
  libraryIssues     LibraryIssue[]
  transportAssignments TransportAssignment[]
  hostelAllocations HostelAllocation[]
  leaveRequests     LeaveRequest[]

  @@unique([schoolId, admissionNumber])
  @@index([schoolId, academicYearId, classId, sectionId])
  @@index([schoolId, status, isArchived])
  @@index([schoolId, fullName])
}

model StudentGuardian {
  id         String   @id @default(cuid())
  studentId  String
  parentId   String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent     Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([studentId, parentId])
}

model Staff {
  id              String        @id @default(cuid())
  schoolId        String
  academicYearId  String
  userId          String?       @unique
  employeeCode    String
  fullName        String
  designation     String
  department      String?
  qualification   String?
  reportingManagerId String?
  isHod           Boolean       @default(false)
  joiningDate     DateTime
  phone           String?
  email           String?
  gender          Gender?
  salaryAmount    Decimal?      @db.Decimal(12, 2)
  isTeachingStaff Boolean       @default(true)
  isArchived      Boolean       @default(false)
  archivedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  school          School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear    AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  reportingManager Staff?       @relation("StaffReportingLine", fields: [reportingManagerId], references: [id], onDelete: SetNull)
  directReports   Staff[]       @relation("StaffReportingLine")
  classTeacherFor Section[]     @relation("ClassTeacher")
  documents       Document[]
  libraryIssues   LibraryIssue[]
  leaveRequests   LeaveRequest[]
  payrollSlips    PayrollSlip[]

  @@unique([schoolId, employeeCode])
  @@index([schoolId, academicYearId, designation])
  @@index([schoolId, isArchived, isTeachingStaff])
  @@index([schoolId, department, isHod])
}

model SchoolClass {
  id             String          @id @default(cuid())
  schoolId       String
  academicYearId String
  name           String
  displayOrder   Int             @default(0)
  isArchived     Boolean         @default(false)
  archivedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  school         School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  sections       Section[]
  students       Student[]
  subjects       Subject[]
  feeStructures  FeeStructure[]
  exams          Exam[]
  notices        Notice[]

  @@unique([schoolId, academicYearId, name])
  @@index([schoolId, academicYearId, displayOrder, isArchived])
}

model Section {
  id               String          @id @default(cuid())
  schoolId         String
  academicYearId   String
  classId          String
  name             String
  classTeacherId   String?
  capacity         Int?
  isArchived       Boolean        @default(false)
  archivedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  school           School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear     AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  class            SchoolClass     @relation(fields: [classId], references: [id], onDelete: Cascade)
  classTeacher     Staff?          @relation("ClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)
  students         Student[]
  notices          Notice[]

  @@unique([schoolId, academicYearId, classId, name])
  @@index([schoolId, classId, isArchived])
}

model Subject {
  id             String         @id @default(cuid())
  schoolId       String
  academicYearId String
  classId        String?
  name           String
  code           String
  isArchived     Boolean        @default(false)
  archivedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  school         School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  class          SchoolClass?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  examSubjects   ExamSubject[]
  examMarks      ExamMark[]

  @@unique([schoolId, academicYearId, code])
  @@index([schoolId, academicYearId, classId, isArchived])
}

model Attendance {
  id             String           @id @default(cuid())
  schoolId       String
  academicYearId String
  studentId      String
  date           DateTime
  status         AttendanceStatus
  remarks        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  school         School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([schoolId, academicYearId, date])
  @@index([schoolId, academicYearId, studentId, date])
  @@index([schoolId, studentId, date])
}

model FeeHead {
  id          String             @id @default(cuid())
  schoolId    String
  name        String
  code        String
  description String?
  isOptional  Boolean            @default(false)
  isArchived  Boolean            @default(false)
  archivedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  school      School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  items       FeeStructureItem[]
  invoiceItems FeeInvoiceItem[]

  @@unique([schoolId, code])
  @@index([schoolId, isArchived])
}

model FeeStructure {
  id             String             @id @default(cuid())
  schoolId       String
  classId        String?
  name           String
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  isArchived     Boolean            @default(false)
  archivedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  school         School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class          SchoolClass?       @relation(fields: [classId], references: [id], onDelete: SetNull)
  items          FeeStructureItem[]

  @@index([schoolId, classId])
  @@index([schoolId, isArchived, effectiveFrom])
}

model FeeStructureItem {
  id             String        @id @default(cuid())
  feeStructureId String
  feeHeadId      String
  amount         Decimal       @db.Decimal(12, 2)
  createdAt      DateTime      @default(now())
  feeStructure   FeeStructure  @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  feeHead        FeeHead       @relation(fields: [feeHeadId], references: [id], onDelete: Restrict)

  @@unique([feeStructureId, feeHeadId])
}

model FeeInvoice {
  id             String           @id @default(cuid())
  schoolId       String
  academicYearId String
  studentId      String
  invoiceNumber  String
  dueDate        DateTime
  status         FeeInvoiceStatus @default(ISSUED)
  totalAmount    Decimal          @db.Decimal(12, 2)
  paidAmount     Decimal          @default(0) @db.Decimal(12, 2)
  discountAmount Decimal          @default(0) @db.Decimal(12, 2)
  fineAmount     Decimal          @default(0) @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  school         School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  items          FeeInvoiceItem[]
  payments       FeePayment[]

  @@unique([schoolId, invoiceNumber])
  @@index([schoolId, studentId, dueDate])
  @@index([schoolId, academicYearId, status, dueDate])
}

model FeePayment {
  id             String         @id @default(cuid())
  schoolId       String
  feeInvoiceId   String
  receiptNumber  String
  paymentDate    DateTime
  amount         Decimal        @db.Decimal(12, 2)
  paymentMode    FeePaymentMode
  referenceNo    String?
  remarks        String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  school         School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  feeInvoice     FeeInvoice     @relation(fields: [feeInvoiceId], references: [id], onDelete: Cascade)

  @@unique([schoolId, receiptNumber])
  @@index([schoolId, paymentDate])
  @@index([schoolId, feeInvoiceId, paymentDate])
}

model FeeInvoiceItem {
  id           String      @id @default(cuid())
  feeInvoiceId String
  feeHeadId    String
  label        String
  amount       Decimal     @db.Decimal(12, 2)
  createdAt    DateTime    @default(now())
  feeInvoice   FeeInvoice  @relation(fields: [feeInvoiceId], references: [id], onDelete: Cascade)
  feeHead      FeeHead     @relation(fields: [feeHeadId], references: [id], onDelete: Restrict)

  @@unique([feeInvoiceId, feeHeadId])
  @@index([feeInvoiceId])
}

model Exam {
  id             String        @id @default(cuid())
  schoolId       String
  academicYearId String
  classId        String?
  name           String
  examTerm       String?
  examType       String?
  startDate      DateTime
  endDate        DateTime
  isArchived     Boolean       @default(false)
  archivedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  class          SchoolClass?  @relation(fields: [classId], references: [id], onDelete: SetNull)
  examSubjects   ExamSubject[]
  examMarks      ExamMark[]
  results        ExamResult[]

  @@index([schoolId, academicYearId, startDate])
  @@index([schoolId, classId, startDate])
  @@index([schoolId, isArchived, startDate])
}

model ExamSubject {
  id          String    @id @default(cuid())
  examId      String
  subjectId   String
  maxMarks    Decimal   @db.Decimal(8, 2)
  passMarks   Decimal   @db.Decimal(8, 2)
  createdAt   DateTime  @default(now())
  exam        Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  examMarks   ExamMark[]

  @@unique([examId, subjectId])
}

model ExamMark {
  id            String    @id @default(cuid())
  examId        String
  examSubjectId String
  subjectId     String
  studentId     String
  marksObtained Decimal   @db.Decimal(8, 2)
  remarks       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  exam          Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  examSubject   ExamSubject @relation(fields: [examSubjectId], references: [id], onDelete: Cascade)
  subject       Subject   @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examSubjectId, studentId])
  @@index([examId, studentId])
}

model ExamResult {
  id               String   @id @default(cuid())
  examId           String
  studentId        String
  totalMarks       Decimal  @db.Decimal(10, 2)
  obtainedMarks    Decimal  @db.Decimal(10, 2)
  percentage       Decimal  @db.Decimal(6, 2)
  grade            String
  resultStatus     String
  teacherRemarks   String?
  principalRemarks String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  exam             Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@index([studentId, createdAt])
  @@index([examId, resultStatus])
}

model Notice {
  id             String             @id @default(cuid())
  schoolId       String
  title          String
  body           String
  audienceType   NoticeAudienceType @default(ALL)
  audienceLabel  String
  roleCode       String?
  classId        String?
  sectionId      String?
  noticeType     String             @default("NORMAL")
  isPublished    Boolean            @default(false)
  isArchived     Boolean            @default(false)
  archivedAt     DateTime?
  publishedAt    DateTime?
  expiresAt      DateTime?
  createdById    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  school         School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class          SchoolClass?       @relation(fields: [classId], references: [id], onDelete: SetNull)
  section        Section?           @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  createdBy      User?              @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([schoolId, publishedAt])
  @@index([schoolId, isPublished, noticeType])
  @@index([schoolId, classId, sectionId, isPublished])
  @@index([schoolId, isArchived, createdAt])
}

model Document {
  id              String             @id @default(cuid())
  schoolId        String
  ownerType       DocumentOwnerType
  studentId       String?
  staffId         String?
  userId          String?
  title           String
  fileName        String
  filePath        String
  mimeType        String?
  fileSizeBytes   Int?
  isArchived      Boolean            @default(false)
  archivedAt      DateTime?
  uploadedAt      DateTime           @default(now())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  school          School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student         Student?           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  staff           Staff?             @relation(fields: [staffId], references: [id], onDelete: Cascade)
  user            User?              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId, ownerType])
  @@index([schoolId, studentId])
  @@index([schoolId, staffId])
  @@index([schoolId, userId])
  @@index([schoolId, isArchived, uploadedAt])
}

model LibraryBook {
  id              String         @id @default(cuid())
  schoolId        String
  accessionNumber String
  title           String
  author          String?
  category        String?
  publisher       String?
  isbn            String?
  shelfLocation   String?
  totalCopies     Int            @default(1)
  availableCopies Int            @default(1)
  isArchived      Boolean        @default(false)
  archivedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  school          School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  issues          LibraryIssue[]

  @@unique([schoolId, accessionNumber])
  @@index([schoolId, title])
  @@index([schoolId, category, isArchived])
}

model LibraryIssue {
  id           String             @id @default(cuid())
  schoolId     String
  bookId       String
  studentId    String?
  staffId      String?
  borrowerName String
  borrowerType String
  issueDate    DateTime
  dueDate      DateTime
  returnedAt   DateTime?
  status       LibraryIssueStatus @default(ISSUED)
  fineAmount   Decimal            @default(0) @db.Decimal(10, 2)
  remarks      String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  school       School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  book         LibraryBook        @relation(fields: [bookId], references: [id], onDelete: Restrict)
  student      Student?           @relation(fields: [studentId], references: [id], onDelete: SetNull)
  staff        Staff?             @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([schoolId, status, issueDate])
  @@index([schoolId, dueDate, status])
  @@index([schoolId, bookId, status])
  @@index([studentId])
  @@index([staffId])
}

model InventoryItem {
  id              String              @id @default(cuid())
  schoolId        String
  itemCode        String
  name            String
  category        String?
  unit            String              @default("pcs")
  supplierName    String?
  location        String?
  minimumQuantity Int                 @default(0)
  quantityOnHand  Int                 @default(0)
  unitCost        Decimal?            @db.Decimal(12, 2)
  isArchived      Boolean             @default(false)
  archivedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  school          School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  movements       InventoryMovement[]

  @@unique([schoolId, itemCode])
  @@index([schoolId, name])
  @@index([schoolId, category, isArchived])
  @@index([schoolId, quantityOnHand, minimumQuantity])
}

model InventoryMovement {
  id           String                @id @default(cuid())
  schoolId     String
  itemId       String
  movementType InventoryMovementType
  quantity     Int
  movementDate DateTime
  reference    String?
  issuedTo     String?
  notes        String?
  createdById  String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  school       School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  item         InventoryItem         @relation(fields: [itemId], references: [id], onDelete: Restrict)
  createdBy    User?                 @relation("InventoryMovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([schoolId, movementDate])
  @@index([schoolId, itemId, movementDate])
  @@index([schoolId, movementType, movementDate])
  @@index([createdById])
}

model TransportVehicle {
  id                  String           @id @default(cuid())
  schoolId            String
  vehicleNumber       String
  vehicleType         String
  capacity            Int
  driverName          String?
  driverPhone         String?
  helperName          String?
  insuranceValidUntil DateTime?
  fitnessValidUntil   DateTime?
  isActive            Boolean          @default(true)
  isArchived          Boolean          @default(false)
  archivedAt          DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  school              School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  routes              TransportRoute[]

  @@unique([schoolId, vehicleNumber])
  @@index([schoolId, isActive, isArchived])
}

model TransportRoute {
  id          String                @id @default(cuid())
  schoolId    String
  vehicleId   String?
  name        String
  code        String
  startPoint  String?
  endPoint    String?
  monthlyFee  Decimal?              @db.Decimal(12, 2)
  isActive    Boolean               @default(true)
  isArchived  Boolean               @default(false)
  archivedAt  DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  school      School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  vehicle     TransportVehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  stops       TransportStop[]
  assignments TransportAssignment[]

  @@unique([schoolId, code])
  @@index([schoolId, vehicleId])
  @@index([schoolId, isActive, isArchived])
}

model TransportStop {
  id          String                  @id @default(cuid())
  schoolId    String
  routeId     String
  name        String
  pickupTime  String?
  dropTime    String?
  stopOrder   Int                     @default(0)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  school      School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  route       TransportRoute          @relation(fields: [routeId], references: [id], onDelete: Cascade)
  assignments TransportAssignment[]

  @@index([schoolId, routeId, stopOrder])
}

model TransportAssignment {
  id         String                    @id @default(cuid())
  schoolId   String
  studentId  String
  routeId    String
  stopId     String?
  startDate  DateTime
  endDate    DateTime?
  status     TransportAssignmentStatus @default(ACTIVE)
  monthlyFee Decimal?                  @db.Decimal(12, 2)
  remarks    String?
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  school     School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student    Student                   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  route      TransportRoute            @relation(fields: [routeId], references: [id], onDelete: Restrict)
  stop       TransportStop?            @relation(fields: [stopId], references: [id], onDelete: SetNull)

  @@index([schoolId, studentId, status])
  @@index([schoolId, routeId, status])
  @@index([schoolId, stopId])
  @@index([schoolId, startDate])
}

model Hostel {
  id          String              @id @default(cuid())
  schoolId    String
  name        String
  code        String
  wardenName  String?
  wardenPhone String?
  address     String?
  isActive    Boolean             @default(true)
  isArchived  Boolean             @default(false)
  archivedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  school      School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  rooms       HostelRoom[]
  allocations HostelAllocation[]

  @@unique([schoolId, code])
  @@index([schoolId, isActive, isArchived])
}

model HostelRoom {
  id          String              @id @default(cuid())
  schoolId    String
  hostelId    String
  roomNumber  String
  floor       String?
  roomType    String?
  capacity    Int
  monthlyFee  Decimal?            @db.Decimal(12, 2)
  isActive    Boolean             @default(true)
  isArchived  Boolean             @default(false)
  archivedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  school      School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  hostel      Hostel              @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  allocations HostelAllocation[]

  @@unique([schoolId, hostelId, roomNumber])
  @@index([schoolId, hostelId, isActive, isArchived])
}

model HostelAllocation {
  id              String                 @id @default(cuid())
  schoolId        String
  studentId       String
  hostelId        String
  roomId          String
  bedNumber       String?
  startDate       DateTime
  endDate         DateTime?
  status          HostelAllocationStatus @default(ACTIVE)
  monthlyFee      Decimal?               @db.Decimal(12, 2)
  guardianConsent Boolean                @default(false)
  remarks         String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  school          School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student         Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  hostel          Hostel                 @relation(fields: [hostelId], references: [id], onDelete: Restrict)
  room            HostelRoom             @relation(fields: [roomId], references: [id], onDelete: Restrict)

  @@index([schoolId, studentId, status])
  @@index([schoolId, hostelId, roomId, status])
  @@index([schoolId, startDate])
}

model LeaveRequest {
  id            String             @id @default(cuid())
  schoolId      String
  requesterType LeaveRequesterType
  studentId     String?
  staffId       String?
  requesterName String
  leaveType     String
  startDate     DateTime
  endDate       DateTime
  totalDays     Decimal            @db.Decimal(6, 2)
  reason        String
  status        LeaveRequestStatus @default(PENDING)
  reviewedById  String?
  reviewedAt    DateTime?
  reviewRemarks String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  school        School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student       Student?           @relation(fields: [studentId], references: [id], onDelete: SetNull)
  staff         Staff?             @relation(fields: [staffId], references: [id], onDelete: SetNull)
  reviewedBy    User?              @relation("LeaveRequestReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([schoolId, requesterType, status, startDate])
  @@index([schoolId, studentId, status])
  @@index([schoolId, staffId, status])
  @@index([reviewedById])
}

model PayrollRun {
  id          String           @id @default(cuid())
  schoolId    String
  title       String
  periodMonth Int
  periodYear  Int
  paymentDate DateTime?
  status      PayrollRunStatus @default(DRAFT)
  notes       String?
  createdById String?
  finalizedAt DateTime?
  paidAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  school      School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy   User?            @relation("PayrollRunCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  slips       PayrollSlip[]

  @@unique([schoolId, periodMonth, periodYear])
  @@index([schoolId, status, paymentDate])
  @@index([schoolId, periodYear, periodMonth])
  @@index([createdById])
}

model PayrollSlip {
  id           String            @id @default(cuid())
  schoolId     String
  payrollRunId String
  staffId      String
  staffName    String
  employeeCode String
  designation  String
  grossPay     Decimal           @db.Decimal(12, 2)
  allowances   Decimal           @default(0) @db.Decimal(12, 2)
  deductions   Decimal           @default(0) @db.Decimal(12, 2)
  netPay       Decimal           @db.Decimal(12, 2)
  status       PayrollSlipStatus @default(DRAFT)
  paymentDate  DateTime?
  remarks      String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  school       School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  payrollRun   PayrollRun        @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  staff        Staff             @relation(fields: [staffId], references: [id], onDelete: Restrict)

  @@unique([payrollRunId, staffId])
  @@index([schoolId, payrollRunId, status])
  @@index([schoolId, staffId, status])
  @@index([schoolId, paymentDate])
}

model ExpenseCategory {
  id          String           @id @default(cuid())
  schoolId    String
  name        String
  code        String
  description String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  school      School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  vouchers    ExpenseVoucher[]

  @@unique([schoolId, code])
  @@index([schoolId, isActive])
}

model ExpenseVoucher {
  id           String               @id @default(cuid())
  schoolId     String
  categoryId   String
  voucherNumber String
  expenseDate  DateTime
  vendorName   String?
  paidTo       String
  amount       Decimal              @db.Decimal(12, 2)
  paymentMode  FeePaymentMode
  referenceNo  String?
  status       ExpenseVoucherStatus @default(DRAFT)
  description  String?
  approvedById String?
  approvedAt   DateTime?
  paidAt       DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  school       School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  category     ExpenseCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  approvedBy   User?                @relation("ExpenseVoucherApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@unique([schoolId, voucherNumber])
  @@index([schoolId, expenseDate])
  @@index([schoolId, status, expenseDate])
  @@index([schoolId, categoryId, status])
  @@index([approvedById])
}

model AuditLog {
  id           String   @id @default(cuid())
  schoolId     String
  actorUserId  String?
  action       String
  entityType   String
  entityId     String?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  actor        User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([schoolId, createdAt])
  @@index([schoolId, action])
  @@index([schoolId, entityType, entityId, createdAt])
}

model Setting {
  id          String   @id @default(cuid())
  schoolId    String
  category    String
  key         String
  value       Json
  isSecret    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, category, key])
  @@index([schoolId, category])
}
